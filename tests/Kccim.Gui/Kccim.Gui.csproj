<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <Target Name="BuildNativeKccim" BeforeTargets="Build">
    <MakeDir Directories="$(OutDir)" />
    <Exec Command="gcc -Wall -Wextra -O2 -shared -DKCCIM_EXPORTS -I$(MSBuildProjectDirectory)\..\..\include -I$(MSBuildProjectDirectory)\..\..\internal -o $(OutDir)kccim.dll $(MSBuildProjectDirectory)\..\..\src\automata.c $(MSBuildProjectDirectory)\..\..\src\table.c $(MSBuildProjectDirectory)\..\..\src\kccim.c" />
  </Target>
</Project>
